{
  "name": "Launchpad for iCloud",
  "description": "Launchpad of your iCloud Apps",
  "version": "3.3.1",
  "action": {
      "default_icon": "src/img/icon.png",
      "default_popup": "popup.html"
  },
  "icons": {
    "128": "src/img/icon.png"
  },
  "permissions": ["contextMenus"],
  "background": {
    "service_worker": "src/background.js"
  },
  "manifest_version": 3,
  "default_locale": "en"
}
